# ====================================================================
# goalworld SPORTS ORACLE - ENVIRONMENT VARIABLES EXAMPLE
# ====================================================================

# Environment Mode: 'development' (for local simulation) or 'production' (for real Devnet/Mainnet)
NODE_ENV=development

# Solana network configuration
RPC_URL=http://127.0.0.1:8899
ORACLE_KEYPAIR_PATH=~/.config/solana/id.json

# goalworld program address (Defaults to our Anchor program ID)
PROGRAM_ID=FbDhM4itBS2Cco7c7PbNvC98Fx7Y5HxqXS1JuXdNcBwg

# Official token config (Required if NODE_ENV=production)
GCH_MINT=GCHx92hJ...
TREASURY_TOKEN_ACCOUNT=GCHtReaSuRy...

# Sports API credentials (for World Cup 2026 real fixtures integration)
SPORTS_API_PROVIDER=api-football
SPORTS_API_KEY=your_rapidapi_key_here
SPORTS_API_URL=https://api-football-v1.p.rapidapi.com/v3
