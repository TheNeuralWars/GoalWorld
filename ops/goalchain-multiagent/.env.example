# Copy to ~/.config/goalworld-multiagent.env on VPS (never commit secrets).

goalworld_MULTIAGENT_ENABLED=0
goalworld_MA_HOST=127.0.0.1
goalworld_MA_PORT=8790
goalworld_MA_TOKEN=change-me-long-random

# mock_llm=1: rule-based routing (no API spend). Set 0 to enable LLM.
goalworld_MA_MOCK_LLM=1

# auto = read OPENROUTER_API_KEY from ~/.fcc/.env (same as FCC / oa-worker) — no new key needed
goalworld_MA_PROVIDER=auto
goalworld_MA_USE_FCC_KEYS=1
goalworld_MA_OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional overrides (skip FCC pool if set)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
goalworld_MA_MODEL=claude-sonnet-4-20250514
goalworld_MA_OPENAI_MODEL=gpt-4o-mini

goalworld_MA_MAX_HOPS=6
GITHUB_REPO=TheNeuralWars/goalworld
HERMES_HOME=/home/goalworld/hermes
