#!/usr/bin/env bash
#
# grok-sync — Nice wrapper for syncing Grok CLI config between Mac and GoalWorld VPS.
#
# This gives you a clean interface like:
#   grok sync server
#   grok sync server --auth
#   grok sync mac --no-skills
#
# It delegates to the real mirror scripts in ops/hermes/.
#

set -euo pipefail

# --- Configuration ---
REPO_ROOT="${GOALWORLD_REPO:-$HOME/GoalWorld}"
SCRIPTS_DIR="$REPO_ROOT/ops/hermes"

PUSH_SCRIPT="$SCRIPTS_DIR/push-grok-mirror-to-server.sh"
PULL_SCRIPT="$SCRIPTS_DIR/install-grok-mirror-mac.sh"

SSH_HOST="${GOALCHAIN_SSH:-ubuntu@89.168.20.135}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() {
  printf "${BLUE}[grok-sync]${NC} %s\n" "$*"
}

error() {
  printf "${RED}[grok-sync] ERROR:${NC} %s\n" "$*" >&2
}

success() {
  printf "${GREEN}[grok-sync]${NC} %s\n" "$*"
}

usage() {
  cat <<EOF
Usage: grok sync <direction> [options]

Directions:
  server     Push from this Mac → GoalWorld VPS
  mac        Pull from GoalWorld VPS → this Mac

Options (passed through to the underlying scripts):
  --auth-only     Only sync auth.json (OAuth tokens)
  --config-only   Only sync config.toml
  --no-skills     Skip syncing skills/
  --no-auth       Skip auth.json
  --no-config     Skip config.toml

Examples:
  grok sync server
  grok sync server --auth-only
  grok sync mac
  grok sync mac --no-skills

You can also call the wrapper directly:
  grok-sync server --auth-only

Environment variables:
  GOALCHAIN_SSH     Override the SSH target (default: ubuntu@89.168.20.135)
  GOALWORLD_REPO    Path to the GoalWorld repo (default: ~/GoalWorld)
EOF
}

# Find the real scripts
find_scripts() {
  if [[ ! -f "$PUSH_SCRIPT" || ! -f "$PULL_SCRIPT" ]]; then
    error "Could not find the Grok mirror scripts."
    error "Expected them at:"
    error "  $PUSH_SCRIPT"
    error "  $PULL_SCRIPT"
    error ""
    error "Make sure you are using a recent clone of GoalWorld."
    exit 1
  fi
}

do_sync() {
  local direction="$1"
  shift || true

  find_scripts

  case "$direction" in
    server|push)
      log "Pushing Grok config from Mac → VPS ($SSH_HOST)"
      bash "$PUSH_SCRIPT" "$@"
      success "Sync to server completed."
      ;;
    mac|pull)
      log "Pulling Grok config from VPS → Mac"
      bash "$PULL_SCRIPT" "$@"
      success "Sync from server completed."
      ;;
    *)
      error "Unknown direction: $direction"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    sync)
      if [[ $# -eq 0 ]]; then
        usage
        exit 0
      fi
      do_sync "$@"
      ;;
    server|push|mac|pull)
      # If they asked for help on a direction, show overall help
      if [[ " $* " == *" --help "* || " $* " == *" -h "* ]]; then
        usage
        exit 0
      fi
      do_sync "$cmd" "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
