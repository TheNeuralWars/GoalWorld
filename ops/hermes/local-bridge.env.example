# Local bridge config (Mac)
# Copy to: ~/.goalworld/local-bridge.env

GITHUB_REPO="TheNeuralWars/goalworld"
LOCAL_BRIDGE_POLL_SECONDS=20
LOCAL_BRIDGE_TIMEOUT_SECONDS=5400

# Base path of your local repo checkout.
LOCAL_REPO_PATH="/Users/NicoPez/goalworld"

# Commands executed when a queued task is claimed.
# Available env vars:
# OA_TASK_OWNER OA_TASK_ISSUE_NUMBER OA_TASK_ISSUE_URL OA_TASK_TITLE OA_TASK_OBJECTIVE OA_TASK_REPO
# Use bash -lc for complex commands.

# Recommended: run Hermes CLI / Claude Code locally for each owner profile.
LOCAL_CURSOR_CMD='bash -lc '\''cd "$OA_TASK_REPO" && opencode run --model xai/grok-4.3 "Implement issue #$OA_TASK_ISSUE_NUMBER (Cursor profile). Objective: $OA_TASK_OBJECTIVE"'\'''
LOCAL_ANTIGRAVITY_CMD='bash -lc '\''cd "$OA_TASK_REPO" && opencode run --model xai/grok-4.3 "Implement issue #$OA_TASK_ISSUE_NUMBER (Antigravity profile). Objective: $OA_TASK_OBJECTIVE"'\'''
LOCAL_HERMES_CMD='bash -lc '\''cd "$OA_TASK_REPO" && opencode run --model xai/grok-4.3 "Implement issue #$OA_TASK_ISSUE_NUMBER (Hermes local profile). Objective: $OA_TASK_OBJECTIVE"'\'''
