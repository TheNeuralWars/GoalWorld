# Hermes 24/7 — goalworld (copy to ~/hermes/config.env)
# Never commit config.env (secrets).
#
# Keys marked [used] are read by ops/hermes/*.sh or oa-webhook.py today.
# Keys marked [planned] are reserved for future intake/Slack integrations.

# --- Repo [used: bootstrap, sync, oa-worker, oa-agent-runner, local bridge] ---
goalworld_REPO_PATH="${HOME}/hermes/workspace/goalworld"
GITHUB_REPO="TheNeuralWars/goalworld"
GITHUB_DEFAULT_BRANCH="main"

# Git author for FCC/OA commits on the server (configure-git-identity.sh)
GIT_AUTHOR_NAME="Hermes"
GIT_AUTHOR_EMAIL="hermes@goalworld.local"

# GitHub PAT for Hermes scripts (create-task, dispatch, worker).
# Option A (recommended on server): bash ops/hermes/sync-github-token-to-config.sh
# Option B: fine-grained PAT → https://github.com/settings/tokens?type=beta
# Option C: rely on `gh auth login` only (leave empty if gh works in cron)
GITHUB_TOKEN=""

# --- Pull / sync [used: sync.sh] ---
RPC_URL="https://api.devnet.solana.com"
PROGRAM_ID="FbDhM4itBS2Cco7c7PbNvC98Fx7Y5HxqXS1JuXdNcBwg"
API_BASE_URL=""
# HEALTH_URL is derived if empty: ${API_BASE_URL}/api/economy/health
HEALTH_URL=""

# --- Webhook intake [used: oa-webhook.py, oa-handsfree-smoketest.sh] ---
OA_WEBHOOK_TOKEN=""
OA_WEBHOOK_ALLOWED_SOURCES=""

# --- X-Scout + research forum [used: oa-x-scout-run.sh, oa-x-scout-discord.py] ---
# DISCORD_RESEARCH_CHANNEL_ID = forum channel "active-research" (not #oa-research-live).
OA_RESEARCH_PUBLISHER_ENABLED=true
OA_X_SCOUT_MIN_INTERVAL_SEC=7200
OA_SCOUT_SCORE_MIN=28
OA_SCOUT_GROK_MODEL="grok-3"
OA_SCOUT_TONE="balanced"
DISCORD_TOKEN=""
# Forum channel active-research (right-click → Copy channel ID)
DISCORD_RESEARCH_CHANNEL_ID="1508206161000923176"
# Manager private channel #openclaw-chat (free_response — no @mention needed)
DISCORD_OPENCLAW_CHAT_ID="1507803555765944421"
DISCORD_RESEARCH_WEBHOOK_URL=""
# Hermes chat: en public / es solo con Nico (WhatsApp privado). Ver configure-hermes-language.sh
DISCORD_MESSAGE_LANG="en"
HERMES_DEFAULT_LANG="en"
HERMES_PRIVATE_LANG="es"
# Dedicated channel for OA worker research findings (separate from X-Scout forum).
# Set via: bash ops/hermes/configure-discord-oa-research.sh <CHANNEL_ID>
# Right-click channel in Discord (Developer Mode on) → Copy Channel ID.
DISCORD_OA_RESEARCH_CHANNEL_ID=""
# Enable OA worker to post research findings to DISCORD_OA_RESEARCH_CHANNEL_ID.
# Set to true after configuring the channel above.
OA_WORKER_PUBLISH_RESEARCH=false

# X autopost only runs when OA_RESEARCH_PUBLISHER_ENABLED=true AND all four keys are set.
OA_X_PUBLISH_ENABLED=false
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_SECRET=""

# --- Health watchdog [used: oa-healthcheck.py] ---
OA_HEALTH_STALE_SECONDS=5400

# --- OpenClaw scout tuning [used: optimize-openclaw-scout.sh, oa-scout-autotune.sh] ---
OA_SCOUT_SCORE_MIN=28
OA_SCOUT_SCORE_MIN_FLOOR=24
OA_SCOUT_SCORE_MIN_CEIL=34
OA_SCOUT_MAX_CANDIDATES=5
OA_SCOUT_NEAR_MISS_MAX=2
OA_SCOUT_TONE=balanced
OA_SCOUT_RADAR_CRON="15 */2 * * *"
OA_SCOUT_SYSTEMD_CALENDAR="*-*-* 0/2:15:00"
OA_SCOUT_GROK_MODEL="grok-3"
OA_SCOUT_SYNTH_CRON="30 9 * * *"
OA_SCOUT_WEEKLY_CRON="0 12 * * 1"
OA_SCOUT_AUTOTUNE_CRON="10 11 * * *"
OA_SCOUT_METRICS_WINDOW_HOURS=48

# --- Manager vs code agent [used: oa-worker.sh, oa-agent-runner.sh, oa-run-code.sh] ---
# Manager (Hermes chat): Grok. Code (repo edits): Hermes CEO on VPS.
OA_MODEL=xai/grok-4.3
OA_CODE_ENGINE=hermes
OA_CODE_MODEL=nvidia/nemotron-3-super-120b-a12b  # Issue #832: NVIDIA NIM provider; requires NVIDIA_NIM_API_KEY
OA_CODE_CMD="${HOME}/.hermes/hermes-agent/venv/bin/python -m hermes_cli.main"
OA_CODE_TIMEOUT_SEC=3600

# --- Wait-mode auto dispatch [used: oa-worker.sh, oa-dispatch-local.sh] ---
# VPS (Linux): opencode/FCC handled by oa-worker; grok via oa-agent-runner.sh
# Mac: cursor/antigravity/opencode => local bridge (oa-dispatch-local.sh)
OA_AGENT_CURSOR_CMD=""
OA_AGENT_ANTIGRAVITY_CMD=""
OA_AGENT_GROK_CMD=""
OA_AGENT_OPENCODE_CMD=""

# --- Cloudflare Tunnel [used: setup-tunnel-xai.sh] ---
TUNNEL_HOSTNAME=
TUNNEL_ID=
TUNNEL_CREDENTIALS_FILE=

# --- LangGraph multi-agent [used: ops/hermes/call-langgraph.sh, empresa: hook] ---
# Service: ops/goalworld-multiagent/ (loopback :8790). Secrets live in ~/.config/goalworld-multiagent.env
goalworld_MA_URL="http://127.0.0.1:8790"
goalworld_MA_TOKEN=""
# goalworld_MA_ENV defaults to ~/.config/goalworld-multiagent.env (goalworld_MULTIAGENT_ENABLED=1 there)

# --- GBrain (memory layer on Hermes VPS) ---
# Key from https://zeroentropy.dev — not included in Copilot/Cursor/Grok subscriptions
ZEROENTROPY_API_KEY=""
# Optional extra keys (gbrain uses ZEROENTROPY_API_KEY only)
ZEROENTROPY_API_KEY_ALT=""

# --- xAI [used: oa-xai-connect.sh, Hermes Manager model] ---
XAI_API_KEY=
XAI_OAUTH_PORT=56121

# --- Planned (not wired in scripts yet) ---
# INTAKE_PATH="docs/intake"
# REQUIRE_NICO_OK_FOR_P0=true
# SLACK_BOT_TOKEN=""
# NOTION_TOKEN=""
# HERMES_NOTIFY_WEBHOOK=""

# --- Buffer + 9:16 video auto-publish (issue #831, default OFF) ---
# Auth: https://buffer.com/developers/api/updates
# BUFFER_ACCESS_TOKEN is the personal/social access token; secret suffix is empty
# so the Basic-auth header becomes "1|<token>:" (per Buffer REST spec).
BUFFER_ACCESS_TOKEN=""
BUFFER_YT_PROFILE_ID=""
BUFFER_X_PROFILE_ID=""
BUFFER_TIKTOK_PROFILE_ID=""
# Reads also:
# - XAI_API_KEY (or fallback alias GROK_API_KEY) for narrative generation
GROK_API_KEY=""
# Master gate for the whole pipeline. "1"/"true"/"yes"/"on" enables real
# Buffer publishes; anything else stays dry-run safe.
ORACLE_VIDEO_BUFFER_PUBLISH="0"
