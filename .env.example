# =============================================================
# goalworld — Shared Network / Cluster Configuration
# =============================================================
# This file is the SINGLE seam for switching the entire monorepo
# between localnet / devnet / mainnet.
#
# Each consumer (SDK, API, Oracle, Webapp) reads its respective
# subset. Do not duplicate values into .env.local — symlink or
# source this file instead.
#
# Note: GCH_TOKEN_MINT is currently a placeholder. The runtime
# resolves the active mint from the on-chain `global_config`
# account whenever possible. Replace with the deployed mint
# when the token is initialized.
# =============================================================

goalworld_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=FbDhM4itBS2Cco7c7PbNvC98Fx7Y5HxqXS1JuXdNcBwg
GCH_TOKEN_MINT=<PENDING_MINT_BASE58>
