# Solana RPC for wallet + on-chain reads
VITE_RPC_URL=https://api.devnet.solana.com

# goalworld API (ops status, economy config/metrics). No trailing slash.
# Dev: local API. Prod: omit or use CRM path (Vercel must NOT use api.goalworld.io until DNS exists).
VITE_API_BASE_URL=http://localhost:3001
# Vercel Production (recommended): leave unset, or:
# VITE_API_BASE_URL=https://crm.goalworld.fun/goalworld-api

# Optional override (defaults to devnet program id in SDK)
# VITE_PROGRAM_ID=FbDhM4itBS2Cco7c7PbNvC98Fx7Y5HxqXS1JuXdNcBwg
