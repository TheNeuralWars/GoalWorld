{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && cd ../sdk && npm install",
  "buildCommand": "cd ../sdk && npm run build && cd ../webapp && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/classic-dashboard.html", "destination": "/classic-dashboard.html" },
    { "source": "/((?!classic-dashboard\\.html).*)", "destination": "/index.html" }
  ]
}
